<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.haha.blog.common.mapper.ArticleMapper">

    <update id="updateReadNumBatch">
        UPDATE t_article
        SET read_num = read_num + CASE id
        <foreach collection="readNumMap" item="increment" index="articleId">
            WHEN #{articleId} THEN #{increment}
        </foreach>
        ELSE 0 END
        WHERE id IN
        <foreach collection="readNumMap" item="increment" index="articleId" open="(" separator="," close=")">
            #{articleId}
        </foreach>
    </update>

    <update id="updateTypeByIds">
        UPDATE t_article
        SET type = #{type}
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <select id="queryTotalViewCount" resultType="java.lang.Long">
        select sum(read_num) from t_article
    </select>

</mapper>
